generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  DRAFT
  PRE_HIRE
  ACTIVE
  ON_LEAVE
  SICK_LEAVE
  LONG_TERM_LEAVE
  SUSPENDED
  TERMINATION_PENDING
  TERMINATED
  ARCHIVED
}

enum Availability {
  AVAILABLE
  AWAY
  REMOTE
}

enum StaffingStatus {
  VACANT
  OCCUPIED
  FROZEN
  CLOSED
}

enum LeaveRequestStatus {
  DRAFT
  SUBMITTED
  MANAGER_REVIEW
  HR_REVIEW
  APPROVED
  REJECTED
  RETURNED_FOR_REVISION
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  staffing  StaffingPosition[]

  @@map("hr_departments")
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  employees Employee[]
  staffing  StaffingPosition[]

  @@map("hr_positions")
}

model StaffingPosition {
  id           String         @id @default(uuid()) @db.Uuid
  code         String         @unique
  departmentId String         @map("department_id") @db.Uuid
  positionId   String         @map("position_id") @db.Uuid
  status       StaffingStatus @default(VACANT)
  fte          Decimal        @default(1) @db.Decimal(4, 2)
  validFrom    DateTime       @map("valid_from") @db.Date
  validTo      DateTime?      @map("valid_to") @db.Date
  salaryMin    Decimal?       @map("salary_min") @db.Decimal(14, 2)
  salaryMax    Decimal?       @map("salary_max") @db.Decimal(14, 2)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  version      Int            @default(1)
  department   Department     @relation(fields: [departmentId], references: [id])
  position     Position       @relation(fields: [positionId], references: [id])
  employee     Employee?

  @@index([departmentId, status])
  @@map("hr_staffing_positions")
}

model Employee {
  id                        String         @id @default(uuid()) @db.Uuid
  employeeNumber            String         @unique @map("employee_number")
  status                    EmployeeStatus @default(DRAFT)
  availability              Availability   @default(AVAILABLE)
  fullName                  String         @map("full_name")
  initials                  String
  workEmail                 String         @unique @map("work_email")
  workPhone                 String         @map("work_phone")
  departmentId              String         @map("department_id") @db.Uuid
  positionId                String         @map("position_id") @db.Uuid
  staffingPositionId        String?        @unique @map("staffing_position_id") @db.Uuid
  managerId                 String?        @map("manager_id") @db.Uuid
  legalEntityId             String         @map("legal_entity_id")
  locationId                String         @map("location_id")
  employmentType            String         @map("employment_type")
  fte                       Decimal        @default(1) @db.Decimal(4, 2)
  workScheduleId            String         @map("work_schedule_id")
  startDate                 DateTime       @map("start_date") @db.Date
  contractEndDate           DateTime?      @map("contract_end_date") @db.Date
  probationStartDate        DateTime?      @map("probation_start_date") @db.Date
  probationEndDate          DateTime?      @map("probation_end_date") @db.Date
  personnelFileCompleteness Int            @default(0) @map("personnel_file_completeness")
  salary                    Decimal?       @db.Decimal(14, 2)
  currency                  String         @default("KZT")
  candidateGroups           String[]       @map("candidate_groups")
  skills                    String[]
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")
  createdBy                 String         @map("created_by")
  updatedBy                 String         @map("updated_by")
  version                   Int            @default(1)
  department                Department     @relation(fields: [departmentId], references: [id])
  position                  Position       @relation(fields: [positionId], references: [id])
  staffingPosition          StaffingPosition? @relation(fields: [staffingPositionId], references: [id])
  manager                   Employee?      @relation("EmployeeManager", fields: [managerId], references: [id])
  reports                   Employee[]     @relation("EmployeeManager")
  leaveBalances             LeaveBalance[]
  leaveRequests             LeaveRequest[] @relation("LeaveEmployee")
  substituteLeaveRequests   LeaveRequest[] @relation("LeaveSubstitute")

  @@index([departmentId])
  @@index([managerId])
  @@index([staffingPositionId])
  @@index([status])
  @@map("hr_employees")
}

model LeaveBalance {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  leaveType   String   @map("leave_type")
  year        Int
  available   Decimal  @db.Decimal(8, 2)
  reserved    Decimal  @default(0) @db.Decimal(8, 2)
  used        Decimal  @default(0) @db.Decimal(8, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  version     Int      @default(1)
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveType, year])
  @@index([employeeId])
  @@map("hr_leave_balances")
}

model LeaveRequest {
  id                   String             @id @default(uuid()) @db.Uuid
  employeeId           String             @map("employee_id") @db.Uuid
  leaveType            String             @map("leave_type")
  startDate            DateTime           @map("start_date") @db.Date
  endDate              DateTime           @map("end_date") @db.Date
  requestedDuration    Decimal            @map("requested_duration") @db.Decimal(8, 2)
  halfDay              Boolean            @default(false) @map("half_day")
  customHours          Decimal?           @map("custom_hours") @db.Decimal(5, 2)
  substituteEmployeeId String?            @map("substitute_employee_id") @db.Uuid
  comment              String?
  contactDuringLeave   String?            @map("contact_during_leave")
  balanceSnapshot      Decimal            @map("balance_snapshot") @db.Decimal(8, 2)
  status               LeaveRequestStatus @default(SUBMITTED)
  documentId           String?            @map("document_id")
  documentNumber       String?            @map("document_number")
  workflowInstanceId   String?            @map("workflow_instance_id")
  workflowStep         String?            @map("workflow_step")
  auditCorrelationId   String             @map("audit_correlation_id")
  idempotencyKey       String             @unique @map("idempotency_key")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  createdBy            String             @map("created_by")
  updatedBy            String             @map("updated_by")
  version              Int                @default(1)
  employee             Employee           @relation("LeaveEmployee", fields: [employeeId], references: [id])
  substitute           Employee?          @relation("LeaveSubstitute", fields: [substituteEmployeeId], references: [id])

  @@index([employeeId, startDate, endDate])
  @@index([status])
  @@index([workflowInstanceId])
  @@index([documentId])
  @@map("hr_leave_requests")
}

model AuditEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  aggregateType      String   @map("aggregate_type")
  aggregateId        String   @map("aggregate_id")
  action             String
  actorId            String   @map("actor_id")
  actorRole          String   @map("actor_role")
  correlationId      String   @map("correlation_id")
  workflowInstanceId String?  @map("workflow_instance_id")
  reason             String?
  changes            Json?
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId])
  @@index([correlationId])
  @@map("hr_audit_events")
}

model OutboxEvent {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String       @map("event_type")
  aggregateType String       @map("aggregate_type")
  aggregateId   String       @map("aggregate_id")
  payload       Json
  correlationId String       @map("correlation_id")
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  createdAt     DateTime     @default(now()) @map("created_at")
  publishedAt   DateTime?    @map("published_at")

  @@index([status, createdAt])
  @@map("hr_outbox_events")
}
